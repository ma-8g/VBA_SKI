Sub CopyAllSheetsData()
    Dim wsDest As Worksheet
    Dim wsSrc As Worksheet
    Dim lastRowDest As Long
    Dim lastRowSrc As Long
    Dim lastColSrc As Long
    Dim copyRange As Range
    Dim pasteRange As Range
    
    ' 画面更新と警告を一時停止（処理高速化のため）
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' コピー先のシートを設定
    On Error Resume Next
    Set wsDest = Sheets("全シート")
    On Error GoTo 0
    
    ' 「全シート」がない場合はエラーメッセージを出して終了
    If wsDest Is Nothing Then
        MsgBox "「全シート」という名前のシートが見つかりません。", vbCritical
        Exit Sub
    End If
    
    ' 各シートをループ処理
    For Each wsSrc In ThisWorkbook.Worksheets
        
        ' コピー先シート、または非表示シートはスキップ
        If wsSrc.Name <> wsDest.Name And wsSrc.Visible = xlSheetVisible Then
            
            ' コピー元シートのA1から値のある最終行・最終列を取得
            lastRowSrc = wsSrc.Cells(wsSrc.Rows.Count, "A").End(xlUp).Row
            lastColSrc = wsSrc.Cells(1, wsSrc.Columns.Count).End(xlToLeft).Column
            
            ' A1セルに値がある場合のみ処理を実行
            If wsSrc.Range("A1").Value <> "" Then
                
                ' コピー元の範囲を設定 (A1からデータが存在する右下まで)
                Set copyRange = wsSrc.Range(wsSrc.Cells(1, 1), wsSrc.Cells(lastRowSrc, lastColSrc))
                
                ' コピー先の最終行を取得（初回は1行目、2回目以降は最終行の次）
                lastRowDest = wsDest.Cells(wsDest.Rows.Count, "A").End(xlUp).Row
                If wsDest.Range("A1").Value = "" Then
                    lastRowDest = 1
                Else
                    lastRowDest = lastRowDest + 1
                End If
                
                ' データをコピーして「全シート」のB列以降に貼り付け（A列を空けるため）
                Set pasteRange = wsDest.Cells(lastRowDest, 2)
                copyRange.Copy pasteRange
                
                ' 貼り付けた行のA列に、コピー元シートのA1セルの値を書き込む
                wsDest.Range(wsDest.Cells(lastRowDest, 1), wsDest.Cells(lastRowDest + copyRange.Rows.Count - 1, 1)).Value = wsSrc.Range("A1").Value
                
            End If
        End If
    Next wsSrc
    
    ' 設定を元に戻す
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "データの集約が完了しました！", vbInformation
End Sub
