Option Explicit

Dim targetWb As Workbook
Dim sheetCount As Long

Sub MergeCheckSheets()
    Dim fso As Object
    Dim rootFolderPath As String
    Dim shellApp As Object
    Dim folderObj As Object
    
    ' 1. 集約先ブック（このマクロを実行しているブック）のセット
    Set targetWb = ThisWorkbook
    sheetCount = 1
    
    ' フォルダ選択ダイアログの表示
    Set shellApp = CreateObject("Shell.Application")
    Set folderObj = shellApp.BrowseForFolder(0, "処理対象のフォルダを選択してください", 0)
    
    If folderObj Is Nothing Then
        MsgBox "フォルダが選択されなかったため、処理を中断します。", vbExclamation
        Exit Sub
    End If
    
    rootFolderPath = folderObj.Self.Path
    
    ' 画面更新と警告の停止（高速化のため）
    With Application
        .ScreenUpdating = False
        .DisplayAlerts = False
        .Calculation = xlCalculationManual
    End With
    
    ' FileSystemObjectのインスタンス作成
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    ' 再帰処理の開始
    ProcessFolder fso.GetFolder(rootFolderPath)
    
    ' 設定の元戻し
    With Application
        .ScreenUpdating = True
        .DisplayAlerts = True
        .Calculation = xlCalculationAutomatic
    End With
    
    MsgBox "処理が完了しました。処理件数: " & (sheetCount - 1) & "件", vbInformation
End Sub

' フォルダを再帰的に処理するサブプロシージャ
Private Sub ProcessFolder(currentFolder As Object)
    Dim fileObj As Object
    Dim subFolder As Object
    Dim sourceWb As Workbook
    Dim ws As Worksheet
    Dim sheetName As String
    
    ' フォルダ内のファイルをループ処理
    For Each fileObj In currentFolder.Files
        ' Excelファイルかつ、一時ファイル（~$で始まるもの）や集約先自身を除外
        If (LCase(fileObj.Name) Like "*.xls*") And _
           (Not fileObj.Name Like "~$*") And _
           (fileObj.Name <> targetWb.Name) Then
            
            On Error Resume Next
            ' ブックを読み取り専用で開く
            Set sourceWb = Workbooks.Open(Filename:=fileObj.Path, ReadOnly:=True)
            
            If Not sourceWb Is Nothing Then
                ' 「チェック仕様」シートが存在するか確認
                Set ws = Nothing
                Set ws = sourceWb.Sheets("チェック仕様")
                
                If Not ws Is Nothing Then
                    ' 3桁の連番シート名を生成（例: 001, 002...）
                    sheetName = Format(sheetCount, "000")
                    
                    ' シートを集約先ブックの末尾にコピー
                    ws.Copy After:=targetWb.Sheets(targetWb.Sheets.Count)
                    
                    ' コピーしたシートの操作
                    With targetWb.Sheets(targetWb.Sheets.Count)
                        .Name = sheetName
                        
                        ' 4. 1行目に行を追加
                        .Rows(1).Insert Shift:=xlDown
                        
                        ' 追加した1行目の書式設定（折り返しなし、左揃え、上揃え）
                        With .Rows(1)
                            .WrapText = False
                            .HorizontalAlignment = xlHAlignLeft
                            .VerticalAlignment = xlVAlignTop
                        End With
                        
                        ' A1にファイル名をセット
                        .Range("A1").Value = sourceWb.Name
                    End With
                    
                    ' カウントをインクリメント
                    sheetCount = sheetCount + 1
                End If
                
                ' 保存せずに閉じる
                sourceWb.Close SaveChanges:=False
            End If
            On Error GoTo 0
        End If
    Next fileObj
    
    ' サブフォルダがある場合は再帰的に呼び出し
    For Each subFolder In currentFolder.SubFolders
        ProcessFolder subFolder
    Next subFolder
End Sub
