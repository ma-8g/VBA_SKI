Option Explicit

Dim targetBk As Workbook
Dim sheetCount As Long

Sub 集約マクロ_開始()
    Dim rFolder As String
    Dim fso As Object
    
    ' 集約先のブック（このマクロを実行しているブック）をセット
    Set targetBk = ThisWorkbook
    sheetCount = 0
    
    ' 処理対象のメインフォルダを選択
    With Application.FileDialog(msoFileDialogFolderPicker)
        .Title = "処理対象のフォルダを選択してください"
        If .Show = True Then
            rFolder = .SelectedItems(1)
        Else
            MsgBox "処理をキャンセルしました。", vbInformation
            Exit Sub
        End If
    End With
    
    ' 画面更新と警告非表示で高速化
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' FileSystemObjectを使ってフォルダ内を再帰的に処理
    Set fso = CreateObject("Scripting.FileSystemObject")
    Call ProcessFiles(fso.GetFolder(rFolder))
    
    ' 設定を元に戻す
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "処理が完了しました！" & vbCrLf & "集約シート数: " & sheetCount & " 件", vbInformation
End Sub

' フォルダを再帰処理するサブプロシージャ
Sub ProcessFiles(currentFolder As Object)
    Dim subFolder As Object
    Dim file As Object
    Dim sourceBk As Workbook
    Dim ws As Worksheet
    Dim newSheetName As String
    
    ' 1. フォルダ内のファイルをひとつずつ確認
    For Each file In currentFolder.Files
        ' Excelファイルかつ、一時ファイル（~$で始まるもの）や自分自身でない場合
        If (file.Name Like "*.xls*") And (Not file.Name Like "~$*") And (file.Name <> targetBk.Name) Then
            
            ' ブックを開く
            Set sourceBk = Workbooks.Open(file.Path, ReadOnly:=True)
            
            ' 「チェック仕様」シートが存在するかチェック
            On Error Resume Next
            Set ws = sourceBk.Sheets("チェック仕様")
            On Error GoTo 0
            
            If Not ws Is Nothing Then
                ' カウントアップ（連番用）
                sheetCount = sheetCount + 1
                ' 3桁の連番（001, 002...）を作成
                newSheetName = Format(sheetCount, "000")
                
                ' 2. シートを「全チェック仕様」ブックの末尾にコピー
                ws.Copy After:=targetBk.Sheets(targetBk.Sheets.Count)
                
                ' コピーされたシートに対して処理
                With targetBk.Sheets(targetBk.Sheets.Count)
                    ' 3. シート名を連番に変更
                    .Name = newSheetName
                    
                    ' 4. 1行目に行を追加し、A1にコピー元ファイル名をセット
                    .Rows(1).Insert Shift:=xlDown
                    .Range("A1").Value = sourceBk.Name
                    ' 少し目立たせるために背景色や太字にしたい場合はここを調整してください
                End With
            End If
            
            ' 変数の初期化とブックを閉じる（保存しない）
            Set ws = Nothing
            sourceBk.Close SaveChanges:=False
        End If
    Next file
    
    ' サブフォルダがある場合は、自分自身を呼び出して再帰処理
    For Each subFolder In currentFolder.SubFolders
        Call ProcessFiles(subFolder)
    Next subFolder
End Sub
